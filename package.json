{
  "name": "saforafrontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:guest": "vite --mode guest",
    "build": "vite build",
    "build:guest": "vite build --mode guest",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:guest": "vite preview --outDir dist-guest --port 4174",
    "type-check": "tsc --noEmit",
    "cap:sync": "npm run build:guest && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^6.3.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/device": "^6.0.3",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/push-notifications": "^6.0.5",
    "@tailwindcss/vite": "^4.2.4",
    "firebase": "^11.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
